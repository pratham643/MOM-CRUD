APP_NAME="MOM CRUD Staging"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.example.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=staging-db.example.internal
DB_PORT=3306
DB_DATABASE=mom_crud_staging
DB_USERNAME=mom_crud_staging
DB_PASSWORD=replace_with_secret_manager_value

CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=database
MAIL_MAILER=smtp

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
